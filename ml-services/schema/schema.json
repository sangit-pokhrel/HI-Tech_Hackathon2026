{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sajiloscore.local/schema/ml-service.schema.json",
  "title": "SajiloScore Bishwas ML Service Schema",
  "version": "1.0.0",
  "description": "Authoritative schema for the SajiloScore/Bishwas ML service covering API ingestion, CSV datasets, feature store, F1-F5 scoring, model training, evaluation, prediction, monitoring, provenance, and security metadata.",
  "type": "object",
  "required": [
    "schema_version",
    "service",
    "entities",
    "datasets",
    "features",
    "scoring",
    "models",
    "prediction",
    "monitoring",
    "security"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "service": {
      "type": "object",
      "required": [
        "name",
        "description",
        "input_mode",
        "output_mode",
        "score_range"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "sajiloscore-ml-service"
        },
        "description": {
          "type": "string"
        },
        "input_mode": {
          "type": "string",
          "enum": ["BACKEND_API"]
        },
        "output_mode": {
          "type": "string",
          "enum": ["API_RESPONSE", "CSV_EXPORT", "MODEL_ARTIFACT"]
        },
        "score_range": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {
              "type": "integer",
              "const": 0
            },
            "max": {
              "type": "integer",
              "const": 1000
            }
          }
        }
      }
    },
    "entities": {
      "type": "object",
      "required": [
        "merchant",
        "customer",
        "transaction",
        "utility_payment",
        "wallet_activity",
        "loan_application",
        "repayment_record",
        "social_edge",
        "psychometric_answer"
      ],
      "properties": {
        "merchant": {
          "$ref": "#/$defs/Merchant"
        },
        "customer": {
          "$ref": "#/$defs/Customer"
        },
        "transaction": {
          "$ref": "#/$defs/Transaction"
        },
        "utility_payment": {
          "$ref": "#/$defs/UtilityPayment"
        },
        "wallet_activity": {
          "$ref": "#/$defs/WalletActivity"
        },
        "loan_application": {
          "$ref": "#/$defs/LoanApplication"
        },
        "repayment_record": {
          "$ref": "#/$defs/RepaymentRecord"
        },
        "social_edge": {
          "$ref": "#/$defs/SocialEdge"
        },
        "psychometric_answer": {
          "$ref": "#/$defs/PsychometricAnswer"
        }
      }
    },
    "datasets": {
      "type": "object",
      "required": [
        "raw_dataset",
        "processed_dataset"
      ],
      "properties": {
        "raw_dataset": {
          "$ref": "#/$defs/RawDataset"
        },
        "processed_dataset": {
          "$ref": "#/$defs/ProcessedDataset"
        }
      }
    },
    "features": {
      "type": "object",
      "required": [
        "merchant_feature_record",
        "feature_definitions"
      ],
      "properties": {
        "merchant_feature_record": {
          "$ref": "#/$defs/MerchantFeatureRecord"
        },
        "feature_definitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FeatureDefinition"
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": [
        "factor_scores",
        "fusion_score",
        "loan_recommendation"
      ],
      "properties": {
        "factor_scores": {
          "$ref": "#/$defs/FactorScores"
        },
        "fusion_score": {
          "$ref": "#/$defs/FusionScore"
        },
        "loan_recommendation": {
          "$ref": "#/$defs/LoanRecommendation"
        }
      }
    },
    "models": {
      "type": "object",
      "required": [
        "training_run",
        "model_registry_record",
        "evaluation_report"
      ],
      "properties": {
        "training_run": {
          "$ref": "#/$defs/TrainingRun"
        },
        "model_registry_record": {
          "$ref": "#/$defs/ModelRegistryRecord"
        },
        "evaluation_report": {
          "$ref": "#/$defs/EvaluationReport"
        }
      }
    },
    "prediction": {
      "type": "object",
      "required": [
        "prediction_request",
        "prediction_response"
      ],
      "properties": {
        "prediction_request": {
          "$ref": "#/$defs/PredictionRequest"
        },
        "prediction_response": {
          "$ref": "#/$defs/PredictionResponse"
        }
      }
    },
    "monitoring": {
      "type": "object",
      "required": [
        "model_monitoring_record",
        "drift_report"
      ],
      "properties": {
        "model_monitoring_record": {
          "$ref": "#/$defs/ModelMonitoringRecord"
        },
        "drift_report": {
          "$ref": "#/$defs/DriftReport"
        }
      }
    },
    "security": {
      "$ref": "#/$defs/SecurityPolicy"
    }
  },
  "$defs": {
    "CommonProvenance": {
      "type": "object",
      "required": [
        "source",
        "source_endpoint",
        "extracted_at",
        "schema_version"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["BACKEND_API", "CSV", "MODEL_OUTPUT", "MANUAL_REVIEW"]
        },
        "source_endpoint": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        },
        "schema_version": {
          "type": "string"
        },
        "batch_id": {
          "type": "string"
        },
        "record_hash": {
          "type": "string"
        }
      }
    },
    "AuditFields": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string"
        },
        "updated_by": {
          "type": "string"
        }
      }
    },
    "Merchant": {
      "type": "object",
      "required": [
        "merchant_id",
        "merchant_code",
        "business_type",
        "wallet_age_months",
        "location"
      ],
      "properties": {
        "merchant_id": {
          "type": "string"
        },
        "merchant_code": {
          "type": "string"
        },
        "merchant_name": {
          "type": "string"
        },
        "owner_name": {
          "type": "string"
        },
        "phone_number": {
          "type": "string"
        },
        "business_type": {
          "type": "string",
          "enum": [
            "TEA_SHOP",
            "GROCERY",
            "RESTAURANT",
            "VEGETABLE_SHOP",
            "AGRICULTURE",
            "PHARMACY",
            "MOBILE_REPAIR",
            "STATIONERY",
            "CLOTHING_STORE",
            "BEAUTY_PARLOUR",
            "MEAT_SHOP",
            "BAKERY",
            "DAIRY_SHOP",
            "CYBER_CAFE",
            "HARDWARE_STORE",
            "SNACK_SHOP",
            "OTHER"
          ]
        },
        "registration_status": {
          "type": "string",
          "enum": ["registered", "unregistered", "in_process"]
        },
        "wallet_age_months": {
          "type": "integer",
          "minimum": 0
        },
        "business_started_year": {
          "type": "integer",
          "minimum": 1950,
          "maximum": 2030
        },
        "location": {
          "type": "object",
          "required": ["district", "municipality", "ward_no"],
          "properties": {
            "province": {
              "type": "string"
            },
            "district": {
              "type": "string"
            },
            "municipality": {
              "type": "string"
            },
            "ward_no": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "is_active": {
          "type": "boolean"
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "Customer": {
      "type": "object",
      "required": [
        "customer_id",
        "customer_code"
      ],
      "properties": {
        "customer_id": {
          "type": "string"
        },
        "customer_code": {
          "type": "string"
        },
        "customer_name": {
          "type": "string"
        },
        "verified_status": {
          "type": "string",
          "enum": ["verified", "unverified"]
        },
        "balance": {
          "type": "number",
          "minimum": 0
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "Transaction": {
      "type": "object",
      "required": [
        "transaction_id",
        "transaction_code",
        "sender_code",
        "receiver_code",
        "amount",
        "transaction_type",
        "status",
        "transaction_time"
      ],
      "properties": {
        "transaction_id": {
          "type": "string"
        },
        "transaction_code": {
          "type": "string"
        },
        "sender_code": {
          "type": "string"
        },
        "receiver_code": {
          "type": "string"
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "transaction_type": {
          "type": "string",
          "enum": [
            "QR_PAYMENT",
            "WALLET_PAYMENT",
            "REFUND",
            "CASH_IN",
            "CASH_OUT",
            "SUPPLIER_PAYMENT",
            "BILL_PAYMENT"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["SUCCESS", "FAILED", "REFUNDED", "PENDING"]
        },
        "payment_channel": {
          "type": "string",
          "enum": ["QR", "WALLET", "BANK_TRANSFER", "CASH"]
        },
        "transaction_growth_rate": {
          "type": "number"
        },
        "transaction_time": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "UtilityPayment": {
      "type": "object",
      "required": [
        "utility_payment_id",
        "merchant_id",
        "bill_type",
        "bill_amount",
        "due_date",
        "payment_status",
        "days_late"
      ],
      "properties": {
        "utility_payment_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "bill_type": {
          "type": "string",
          "enum": ["ELECTRICITY", "WATER", "INTERNET", "MOBILE_TOPUP", "REMITTANCE"]
        },
        "bill_amount": {
          "type": "number",
          "minimum": 0
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "paid_date": {
          "type": ["string", "null"],
          "format": "date"
        },
        "payment_status": {
          "type": "string",
          "enum": ["ON_TIME", "LATE", "MISSED", "UNPAID", "PAID_EARLY"]
        },
        "days_late": {
          "type": "integer",
          "minimum": 0
        },
        "provider": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "WalletActivity": {
      "type": "object",
      "required": [
        "wallet_activity_id",
        "merchant_id",
        "activity_type",
        "amount",
        "balance_after_transaction",
        "activity_time"
      ],
      "properties": {
        "wallet_activity_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "activity_type": {
          "type": "string",
          "enum": [
            "PAYMENT_RECEIVED",
            "CASH_IN",
            "CASH_OUT",
            "SUPPLIER_PAYMENT",
            "BILL_PAYMENT",
            "LOAN_REPAYMENT",
            "REMITTANCE_RECEIVED"
          ]
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "balance_after_transaction": {
          "type": "number"
        },
        "activity_time": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "LoanApplication": {
      "type": "object",
      "required": [
        "loan_application_id",
        "merchant_id",
        "requested_amount",
        "loan_purpose",
        "preferred_repayment_type",
        "application_status",
        "applied_at"
      ],
      "properties": {
        "loan_application_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "requested_amount": {
          "type": "number",
          "minimum": 0
        },
        "approved_amount": {
          "type": "number",
          "minimum": 0
        },
        "loan_purpose": {
          "type": "string"
        },
        "preferred_repayment_type": {
          "type": "string",
          "enum": ["DAILY", "WEEKLY", "MONTHLY", "SEASONAL"]
        },
        "application_status": {
          "type": "string",
          "enum": ["PENDING", "APPROVED", "REVIEW", "REJECTED", "DISBURSED", "CLOSED"]
        },
        "applied_at": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "RepaymentRecord": {
      "type": "object",
      "required": [
        "repayment_id",
        "loan_application_id",
        "merchant_id",
        "due_amount",
        "paid_amount",
        "due_date",
        "repayment_status",
        "days_late",
        "ml_target_default"
      ],
      "properties": {
        "repayment_id": {
          "type": "string"
        },
        "loan_application_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "due_amount": {
          "type": "number",
          "minimum": 0
        },
        "paid_amount": {
          "type": "number",
          "minimum": 0
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "paid_date": {
          "type": ["string", "null"],
          "format": "date"
        },
        "repayment_status": {
          "type": "string",
          "enum": ["PAID_ON_TIME", "PAID_LATE", "MISSED", "DEFAULT", "PENDING"]
        },
        "days_late": {
          "type": "integer",
          "minimum": 0
        },
        "ml_target_default": {
          "type": "integer",
          "enum": [0, 1]
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "SocialEdge": {
      "type": "object",
      "required": [
        "edge_id",
        "source_merchant_id",
        "target_entity_type",
        "target_entity_id",
        "relationship_type",
        "trust_strength"
      ],
      "properties": {
        "edge_id": {
          "type": "string"
        },
        "source_merchant_id": {
          "type": "string"
        },
        "target_entity_type": {
          "type": "string",
          "enum": ["CUSTOMER", "SUPPLIER", "GUARANTOR", "MERCHANT"]
        },
        "target_entity_id": {
          "type": "string"
        },
        "relationship_type": {
          "type": "string",
          "enum": [
            "REGULAR_CUSTOMER",
            "SUPPLIER",
            "GUARANTOR",
            "BUSINESS_REFERENCE",
            "B2B_COUNTERPARTY"
          ]
        },
        "trust_strength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_transaction_value": {
          "type": "number",
          "minimum": 0
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "PsychometricAnswer": {
      "type": "object",
      "required": [
        "answer_id",
        "merchant_id",
        "question_id",
        "selected_option",
        "raw_score",
        "normalized_score",
        "response_time_ms",
        "answered_at"
      ],
      "properties": {
        "answer_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "question_id": {
          "type": "string"
        },
        "selected_option": {
          "type": "string",
          "enum": ["A", "B", "C", "D"]
        },
        "raw_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "normalized_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "response_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "consistency_flag": {
          "type": "boolean"
        },
        "answered_at": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "RawDataset": {
      "type": "object",
      "required": [
        "dataset_id",
        "dataset_version",
        "source_api_base_url",
        "exported_at",
        "collections",
        "provenance"
      ],
      "properties": {
        "dataset_id": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        },
        "source_api_base_url": {
          "type": "string"
        },
        "exported_at": {
          "type": "string",
          "format": "date-time"
        },
        "collections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "endpoint", "csv_path", "record_count"],
            "properties": {
              "name": {
                "type": "string"
              },
              "endpoint": {
                "type": "string"
              },
              "csv_path": {
                "type": "string"
              },
              "record_count": {
                "type": "integer",
                "minimum": 0
              },
              "checksum": {
                "type": "string"
              }
            }
          }
        },
        "provenance": {
          "$ref": "#/$defs/CommonProvenance"
        }
      }
    },
    "ProcessedDataset": {
      "type": "object",
      "required": [
        "dataset_id",
        "dataset_version",
        "raw_dataset_id",
        "csv_path",
        "merchant_count",
        "feature_count",
        "target_column",
        "created_at"
      ],
      "properties": {
        "dataset_id": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        },
        "raw_dataset_id": {
          "type": "string"
        },
        "csv_path": {
          "type": "string"
        },
        "merchant_count": {
          "type": "integer",
          "minimum": 0
        },
        "feature_count": {
          "type": "integer",
          "minimum": 0
        },
        "target_column": {
          "type": "string",
          "enum": ["default_label", "repayment_outcome"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "FeatureDefinition": {
      "type": "object",
      "required": [
        "name",
        "dtype",
        "source_entities",
        "description",
        "allowed_range",
        "is_training_feature"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "dtype": {
          "type": "string",
          "enum": ["integer", "number", "string", "boolean", "categorical"]
        },
        "source_entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "allowed_range": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          }
        },
        "is_training_feature": {
          "type": "boolean"
        },
        "fairness_note": {
          "type": "string"
        }
      }
    },
    "MerchantFeatureRecord": {
      "type": "object",
      "required": [
        "merchant_id",
        "dataset_version",
        "features",
        "targets",
        "feature_generated_at"
      ],
      "properties": {
        "merchant_id": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        },
        "features": {
          "type": "object",
          "required": [
            "monthly_revenue_avg",
            "active_days_ratio",
            "transaction_growth_rate",
            "supplier_payment_ratio",
            "wallet_velocity_score",
            "transaction_gravity_score",
            "liquidity_buffer_score",
            "remittance_security_score",
            "airtime_consistency_score",
            "utility_calibration_score",
            "micro_obligation_score",
            "social_pagerank_score",
            "collusion_safety_score",
            "guarantor_health_score",
            "psychometric_avg",
            "conscientiousness_score",
            "risk_decision_consistency_score",
            "customer_diversity_score",
            "repeat_customer_ratio",
            "refund_rate",
            "failed_payment_rate",
            "cashout_speed_score",
            "loan_to_income_ratio",
            "suspicious_spike_score",
            "seasonal_pattern_score",
            "repayment_consistency_score"
          ],
          "properties": {
            "monthly_revenue_avg": {
              "type": "number",
              "minimum": 0
            },
            "active_days_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "transaction_growth_rate": {
              "type": "number"
            },
            "supplier_payment_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "wallet_velocity_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "transaction_gravity_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "liquidity_buffer_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "remittance_security_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "airtime_consistency_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "utility_calibration_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "micro_obligation_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "social_pagerank_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "collusion_safety_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "guarantor_health_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "psychometric_avg": {
              "type": "number",
              "minimum": 0,
              "maximum": 1000
            },
            "conscientiousness_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "risk_decision_consistency_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "customer_diversity_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "repeat_customer_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "refund_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "failed_payment_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "cashout_speed_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "loan_to_income_ratio": {
              "type": "number",
              "minimum": 0
            },
            "suspicious_spike_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "seasonal_pattern_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "repayment_consistency_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "targets": {
          "type": "object",
          "required": ["repayment_outcome", "default_label"],
          "properties": {
            "repayment_outcome": {
              "type": "string",
              "enum": ["GOOD", "LATE", "DEFAULT"]
            },
            "default_label": {
              "type": "integer",
              "enum": [0, 1]
            }
          }
        },
        "feature_generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "FactorScores": {
      "type": "object",
      "required": [
        "merchant_id",
        "f1_livelihood_rhythm",
        "f2_cash_flow_elasticity",
        "f3_smart_digital_footprint",
        "f4_community_trust_graph",
        "f5_psychometric",
        "fraud_penalty"
      ],
      "properties": {
        "merchant_id": {
          "type": "string"
        },
        "f1_livelihood_rhythm": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200
        },
        "f2_cash_flow_elasticity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 180
        },
        "f3_smart_digital_footprint": {
          "type": "integer",
          "minimum": 0,
          "maximum": 220
        },
        "f4_community_trust_graph": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200
        },
        "f5_psychometric": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200
        },
        "fraud_penalty": {
          "type": "integer",
          "minimum": 0,
          "maximum": 250
        },
        "factor_version": {
          "type": "string"
        }
      }
    },
    "FusionScore": {
      "type": "object",
      "required": [
        "merchant_id",
        "factor_scores",
        "ml_repayment_score",
        "final_sajilo_score",
        "risk_band",
        "decision"
      ],
      "properties": {
        "merchant_id": {
          "type": "string"
        },
        "factor_scores": {
          "$ref": "#/$defs/FactorScores"
        },
        "ml_repayment_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "final_sajilo_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "risk_band": {
          "type": "string",
          "enum": ["PLATINUM", "GOLD", "SILVER", "BRONZE", "WATCH", "THIN_FILE"]
        },
        "decision": {
          "type": "string",
          "enum": ["APPROVED", "REVIEW", "REJECTED", "MICRO_CREDIT_ONLY"]
        },
        "formula": {
          "type": "string",
          "const": "F1+F2+F3+F4+F5-fraud_penalty blended with ML repayment score where configured"
        },
        "calculated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "LoanRecommendation": {
      "type": "object",
      "required": [
        "merchant_id",
        "suggested_loan_amount",
        "repayment_plan",
        "risk_band",
        "decision"
      ],
      "properties": {
        "merchant_id": {
          "type": "string"
        },
        "suggested_loan_amount": {
          "type": "number",
          "minimum": 0
        },
        "repayment_plan": {
          "type": "string",
          "enum": ["DAILY", "WEEKLY", "MONTHLY", "SEASONAL", "NONE"]
        },
        "risk_band": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "improvement_tips": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TrainingRun": {
      "type": "object",
      "required": [
        "training_run_id",
        "model_name",
        "model_type",
        "algorithm",
        "dataset_id",
        "dataset_version",
        "target_column",
        "feature_columns",
        "started_at",
        "status"
      ],
      "properties": {
        "training_run_id": {
          "type": "string"
        },
        "model_name": {
          "type": "string"
        },
        "model_type": {
          "type": "string",
          "enum": ["CREDIT_RISK", "FRAUD_ANOMALY", "SEGMENTATION", "PSYCHOMETRIC_RULES"]
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "LogisticRegression",
            "RandomForest",
            "GradientBoosting",
            "XGBoost",
            "LightGBM",
            "IsolationForest",
            "KMeans",
            "RuleBased"
          ]
        },
        "dataset_id": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        },
        "target_column": {
          "type": "string"
        },
        "feature_columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hyperparameters": {
          "type": "object"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["STARTED", "COMPLETED", "FAILED"]
        }
      }
    },
    "EvaluationReport": {
      "type": "object",
      "required": [
        "evaluation_id",
        "training_run_id",
        "metrics"
      ],
      "properties": {
        "evaluation_id": {
          "type": "string"
        },
        "training_run_id": {
          "type": "string"
        },
        "metrics": {
          "type": "object",
          "properties": {
            "accuracy": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "precision": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "recall": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "f1_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "roc_auc": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "false_positive_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "false_negative_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "confusion_matrix": {
          "type": "array"
        },
        "feature_importance": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["feature_name", "importance"],
            "properties": {
              "feature_name": {
                "type": "string"
              },
              "importance": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "ModelRegistryRecord": {
      "type": "object",
      "required": [
        "model_id",
        "model_name",
        "model_version",
        "training_run_id",
        "artifact_path",
        "status",
        "registered_at"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "model_name": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "training_run_id": {
          "type": "string"
        },
        "artifact_path": {
          "type": "string"
        },
        "feature_schema_version": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["CANDIDATE", "STAGING", "PRODUCTION", "ARCHIVED"]
        },
        "registered_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_by": {
          "type": "string"
        }
      }
    },
    "PredictionRequest": {
      "type": "object",
      "required": [
        "request_id",
        "merchant_id",
        "requested_at"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "include_explanation": {
          "type": "boolean",
          "default": true
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "PredictionResponse": {
      "type": "object",
      "required": [
        "request_id",
        "merchant_id",
        "model_version",
        "scores",
        "loan_recommendation",
        "explanation",
        "predicted_at"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "merchant_id": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "scores": {
          "$ref": "#/$defs/FusionScore"
        },
        "probabilities": {
          "type": "object",
          "properties": {
            "default_probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "repayment_probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "loan_recommendation": {
          "$ref": "#/$defs/LoanRecommendation"
        },
        "explanation": {
          "type": "object",
          "required": [
            "summary",
            "positive_factors",
            "risk_factors"
          ],
          "properties": {
            "summary": {
              "type": "string"
            },
            "positive_factors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "risk_factors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "shap_values_ref": {
              "type": "string"
            }
          }
        },
        "predicted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ModelMonitoringRecord": {
      "type": "object",
      "required": [
        "monitoring_id",
        "model_version",
        "window_start",
        "window_end",
        "prediction_count",
        "created_at"
      ],
      "properties": {
        "monitoring_id": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "window_start": {
          "type": "string",
          "format": "date-time"
        },
        "window_end": {
          "type": "string",
          "format": "date-time"
        },
        "prediction_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_score": {
          "type": "number"
        },
        "approval_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "review_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rejection_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "DriftReport": {
      "type": "object",
      "required": [
        "drift_report_id",
        "model_version",
        "dataset_version",
        "drift_status",
        "checked_at"
      ],
      "properties": {
        "drift_report_id": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        },
        "drift_status": {
          "type": "string",
          "enum": ["NO_DRIFT", "WARNING", "DRIFT_DETECTED"]
        },
        "drift_metrics": {
          "type": "object"
        },
        "affected_features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "SecurityPolicy": {
      "type": "object",
      "required": [
        "pii_handling",
        "allowed_sensitive_fields",
        "disallowed_features",
        "audit_required",
        "explainability_required"
      ],
      "properties": {
        "pii_handling": {
          "type": "string",
          "enum": ["MINIMIZE", "HASH_OR_MASK", "DO_NOT_EXPORT_TO_MODEL"]
        },
        "allowed_sensitive_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "disallowed_features": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "gender",
            "caste",
            "religion",
            "ethnicity",
            "political_affiliation",
            "precise_geolocation"
          ]
        },
        "audit_required": {
          "type": "boolean",
          "const": true
        },
        "explainability_required": {
          "type": "boolean",
          "const": true
        },
        "manual_review_required_for": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "HIGH_FRAUD_PENALTY",
              "THIN_FILE",
              "LOW_CONFIDENCE",
              "DRIFT_DETECTED",
              "COLLUSION_RISK"
            ]
          }
        }
      }
    }
  }
}